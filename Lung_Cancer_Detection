==========================================\n","\n","import os\n","import numpy as np\n","import matplotlib.pyplot as plt\n","\n","from tqdm import tqdm\n","\n","import torch\n","import torch.nn as nn\n","from torch.utils.data import Dataset, DataLoader\n","\n","import segmentation_models_pytorch as smp\n","\n","# =========================================================\n","# CONFIG\n","# =========================================================\n","\n","TRAIN_PATH = \"/kaggle/working/combined_dataset/train\"\n","VAL_PATH = \"/kaggle/working/combined_dataset/val\"\n","\n","MODEL_PATH = \"/kaggle/input/datasets/abusalehalamkhan/improved-model/best_model_improved.pth\"\n","\n","SAVE_PATH = \"/kaggle/working/best_model_lidc20.pth\"\n","\n","DEVICE = \"cuda\" if torch.cuda.is_available() else \"cpu\"\n","\n","BATCH_SIZE = 8\n","LR = 1e-5\n","EPOCHS = 15\n","\n","IMAGE_SIZE = 256\n","\n","# =========================================================\n","# DATASET CLASS\n","# =========================================================\n","\n","class LungDataset(Dataset):\n","\n","    def __init__(self, root_dir):\n","\n","        self.samples = []\n","\n","        patients = os.listdir(root_dir)\n","\n","        for patient in patients:\n","\n","            patient_path = os.path.join(root_dir, patient)\n","\n","            data_dir = os.path.join(patient_path, \"data\")\n","            mask_dir = os.path.join(patient_path, \"masks\")\n","\n","            if not os.path.exists(data_dir):\n","                continue\n","\n","            files = os.listdir(data_dir)\n","\n","            for file in files:\n","\n","                img_path = os.path.join(data_dir, file)\n","                mask_path = os.path.join(mask_dir, file)\n","\n","                self.samples.append((img_path, mask_path))\n","\n","    def __len__(self):\n","        return len(self.samples)\n","\n","    def __getitem__(self, idx):\n","\n","        img_path, mask_path = self.samples[idx]\n","\n","        image = np.load(img_path).astype(np.float32)\n","        mask = np.load(mask_path).astype(np.float32)\n","\n","        # channel dimension\n","        image = np.expand_dims(image, axis=0)\n","        mask = np.expand_dims(mask, axis=0)\n","\n","        image = torch.tensor(image, dtype=torch.float32)\n","        mask = torch.tensor(mask, dtype=torch.float32)\n","\n","        return image, mask\n","\n","# =========================================================\n","# DATA LOADERS\n","# =========================================================\n","\n","train_dataset = LungDataset(TRAIN_PATH)\n","val_dataset = LungDataset(VAL_PATH)\n","\n","train_loader = DataLoader(\n","    train_dataset,\n","    batch_size=BATCH_SIZE,\n","    shuffle=True,\n","    num_workers=2\n",")\n","\n","val_loader = DataLoader(\n","    val_dataset,\n","    batch_size=BATCH_SIZE,\n","    shuffle=False,\n","    num_workers=2\n",")\n","\n","print(\"TRAIN SAMPLES:\", len(train_dataset))\n","print(\"VAL SAMPLES:\", len(val_dataset))\n","\n","# =========================================================\n","# MODEL\n","# =========================================================\n","\n","model = smp.UnetPlusPlus(\n","    encoder_name=\"resnet34\",\n","    encoder_weights=None,\n","    in_channels=1,\n","    classes=1\n",")\n","\n","# =========================================================\n","# LOAD PREVIOUS BEST MODEL\n","# =========================================================\n","\n","model.load_state_dict(\n","    torch.load(MODEL_PATH, map_location=DEVICE)\n",")\n","\n","model = model.to(DEVICE)\n","\n","print(\"PRETRAINED MODEL LOADED!\")\n","\n","# =========================================================\n","# FREEZE ENCODER INITIALLY\n","# =========================================================\n","\n","for param in model.encoder.parameters():\n","    param.requires_grad = False\n","\n","print(\"ENCODER FROZEN\")\n","\n","# =========================================================\n","