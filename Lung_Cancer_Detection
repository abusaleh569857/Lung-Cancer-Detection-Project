warnings.filterwarnings(\"ignore\")\n","\n","# ---------------- IMPORTS ----------------\n","!pip install segmentation_models_pytorch -q\n","\n","import torch\n","import segmentation_models_pytorch as smp\n","import numpy as np\n","from pathlib import Path\n","from tqdm import tqdm\n","\n","# ---------------- CONFIG ----------------\n","DEVICE = 'cuda' if torch.cuda.is_available() else 'cpu'\n","MODEL_PATH = '/kaggle/input/lung-cancer-segmentation-model/best_model.pth'\n","DATA_DIR = Path('/kaggle/input/lung-cancer-segment/val')\n","\n","# ---------------- LOAD MODEL ----------------\n","model = smp.UnetPlusPlus(\n","    encoder_name=\"resnet34\",\n","    encoder_weights=None,\n","    in_channels=1,\n","    classes=1,\n","    activation=None\n",")\n","\n","model.load_state_dict(torch.load(MODEL_PATH, map_location=DEVICE))\n","model.to(DEVICE)\n","model.eval()\n","\n","print(\"✅ Model Loaded\")\n","\n","# ---------------- GET FILES ----------------\n","all_files = list(DATA_DIR.glob('**/*.npy'))\n","image_files = [f for f in all_files if 'data' in str(f) or 'images' in str(f)]\n","\n","print(f\"Total Validation Images: {len(image_files)}\")\n","\n","# ---------------- THRESHOLD SEARCH ----------------\n","thresholds = np.arange(0.05, 0.6, 0.05)\n","\n","best_dice = 0\n","best_threshold = 0\n","best_metrics = None\n","\n","for THRESHOLD in thresholds:\n","\n","    TP = TN = FP = FN = 0\n","\n","    for img_path in tqdm(image_files, leave=False):\n","        try:\n","            image = np.load(img_path).astype(np.float32)\n","            mask_path = Path(str(img_path).replace('data','masks').replace('images','masks'))\n","            if not mask_path.exists():\n","                continue\n","\n","            true_mask = np.load(mask_path).astype(np.float32)\n","\n","            # Normalize\n","            if image.max() > image.min():\n","                image = (image - image.min()) / (image.max() - image.min())\n","\n","            img_t = torch.from_numpy(image).unsqueeze(0).unsqueeze(0).float().to(DEVICE)\n","            img_t = (img_t - 0.5) / 0.5\n","\n","            with torch.no_grad():\n","                logits = model(img_t)\n","                pred_prob = torch.sigmoid(logits).cpu().numpy().squeeze()\n","                pred_mask = (pred_prob > THRESHOLD).astype(np.uint8)\n","\n","            true_mask = (true_mask > 0.5).astype(np.uint8)\n","\n","            TP += np.sum((pred_mask==1) & (true_mask==1))\n","            TN += np.sum((pred_mask==0) & (true_mask==0))\n","            FP += np.sum((pred_mask==1) & (true_mask==0))\n","            FN += np.sum((pred_mask==0) & (true_mask==1))\n","\n","        except:\n","            continue\n","\n","    accuracy = (TP+TN)/(TP+TN+FP+FN+1e-8)\n","    precision = TP/(TP+FP+1e-8)\n","    recall = TP/(TP+FN+1e-8)\n","    f1 = 2*precision*recall/(precision+recall+1e-8)\n","    iou = TP/(TP+FP+FN+1e-8)\n","    dice = (2*TP)/(2*TP+FP+FN+1e-8)\n","\n","    print(f\"\\nThreshold {THRESHOLD:.2f}\")\n","    print(f\"Dice: {dice:.4f} | IoU: {iou:.4f} | F1: {f1:.4f}\")\n","\n","    if dice > best_dice:\n","        best_dice = dice\n","        best_threshold = THRESHOLD\n","        best_metrics = (accuracy, precision, recall, f1, iou, dice)\n","\n","# ---------------- FINAL RESULT ----------------\n","print(\"\\n🏆 BEST THRESHOLD FOUND:\", best_threshold)\n","print(\"=\"*50)\n","print(f\"Dice      : {best_metrics[5]:.4f}\")\n","print(f\"IoU       : {best_metrics[4]:.4f}\")\n","print(f\"Accuracy  : {best_metrics[0]:.4f}\")\n","print(f\"Precision : {best_metrics[1]:.4f}\")\n","print(f\"Recall    : {best_metrics[2]:.4f}\")\n","print(f\"F1 Score  : {best_metrics[3]:.4f}\")"]}],"metadata":{"kaggle":{"accelerator":"nvidiaTeslaT4","dataSources":[{"databundleVersionId":5982851,"datasetId":3391284,"sourceId":5905519,"sourceType":"datasetVersion"},{"databundleVersionId":15260054,"datasetId":9224089,"sourceId":14440980,"sourceType":"datasetVersion"}],"dockerImageVersionId":31234,"isGpuEnabled":tru